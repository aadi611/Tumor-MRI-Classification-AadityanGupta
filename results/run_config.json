{
  "seed": 42,
  "img_size": 224,
  "batch_size": 32,
  "num_workers": 0,
  "val_split": 0.15,
  "test_split": 0.15,
  "resplit_data": true,
  "use_crop": true,
  "use_clahe": true,
  "clahe_clip_limit": 2.0,
  "clahe_grid": [
    8,
    8
  ],
  "aug_rotation_deg": 15,
  "aug_translate": 0.08,
  "aug_zoom": [
    0.9,
    1.0
  ],
  "aug_brightness": 0.1,
  "aug_contrast": 0.1,
  "aug_hflip_p": 0.5,
  "label_smoothing": 0.0,
  "weight_decay": 0.0001,
  "use_class_weights": true,
  "use_amp": true,
  "loss_type": "cross_entropy",
  "focal_gamma": 2.0,
  "lr_scheduler": "plateau",
  "use_mixup": false,
  "mixup_alpha": 0.2,
  "scratch_epochs": 40,
  "scratch_lr": 0.0003,
  "phase1_epochs": 12,
  "phase1_lr": 0.001,
  "phase2_epochs": 25,
  "phase2_lr": 1e-05,
  "unfreeze_fraction": 0.3,
  "early_stop_patience": 7,
  "early_stop_min_delta": 0.0001,
  "lr_plateau_patience": 3,
  "lr_plateau_factor": 0.3,
  "dropout_head": 0.4,
  "model_names": [
    "resnet50",
    "densenet121",
    "efficientnet_b3",
    "efficientnet_b0",
    "mobilenet_v3"
  ],
  "use_tta": true,
  "device": "cuda",
  "split_sizes": {
    "train": 2284,
    "val": 490,
    "test": 490
  }
}